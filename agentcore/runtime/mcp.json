{
  "_comment": "OCR Agent Runtime Configuration",
  "mcpServers": {
    "time": {
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": [],
      "timeout": 30000,
      "retryAttempts": 3,
      "retryDelay": 1000
    },
    "aws-cli": {
      "command": "uvx",
      "args": [
        "mcp-server-aws-cli"
      ],
      "env": {
        "AWS_REGION": "us-west-2",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [
        "dynamodb_query",
        "dynamodb_get_item",
        "dynamodb_scan"
      ],
      "timeout": 30000,
      "retryAttempts": 3,
      "retryDelay": 1000
    },
    "database": {
      "command": "uvx",
      "args": [
        "mcp-server-database"
      ],
      "env": {
        "DB_TYPE": "dynamodb",
        "AWS_REGION": "us-west-2",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [
        "query_table",
        "get_item",
        "compare_data"
      ],
      "timeout": 30000,
      "retryAttempts": 3,
      "retryDelay": 1000
    },
    "validation": {
      "command": "uvx",
      "args": [
        "mcp-server-validation"
      ],
      "env": {
        "VALIDATION_MODE": "strict",
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [
        "validate_data",
        "compare_records",
        "detect_discrepancies"
      ],
      "timeout": 45000,
      "retryAttempts": 3,
      "retryDelay": 1000
    }
  },
  "globalSettings": {
    "maxConcurrentSessions": 1,
    "sessionTimeout": 60000,
    "enableSessionReuse": true,
    "logLevel": "ERROR",
    "connectionPoolSize": 1,
    "healthCheckInterval": 30000,
    "gracefulShutdownTimeout": 5000
  }
}